{
  "version": "2.1.0",
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "informationUri": "https://github.com/AgentSafe-AI/tooltrust-scanner",
          "name": "ToolTrust Scanner",
          "rules": []
        }
      },
      "results": [
        {
          "ruleId": "AS-002",
          "level": "warning",
          "message": {
            "text": "tool declares fs permission"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "read_file"
                }
              }
            }
          ]
        },
        {
          "ruleId": "AS-002",
          "level": "warning",
          "message": {
            "text": "tool declares fs permission"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "write_file"
                }
              }
            }
          ]
        },
        {
          "ruleId": "AS-002",
          "level": "warning",
          "message": {
            "text": "tool declares fs permission"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "list_directory"
                }
              }
            }
          ]
        },
        {
          "ruleId": "AS-002",
          "level": "warning",
          "message": {
            "text": "tool declares fs permission"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "search_files"
                }
              }
            }
          ]
        },
        {
          "ruleId": "AS-002",
          "level": "error",
          "message": {
            "text": "tool declares network permission"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "fetch_url"
                }
              }
            }
          ]
        },
        {
          "ruleId": "AS-003",
          "level": "error",
          "message": {
            "text": "tool name \"fetch_url\" implies read-only operation but declares network permission"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "fetch_url"
                }
              }
            }
          ]
        },
        {
          "ruleId": "AS-011",
          "level": "note",
          "message": {
            "text": "tool performs network or execution operations but declares no rate-limit, timeout, or retry configuration"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "fetch_url"
                }
              }
            }
          ]
        },
        {
          "ruleId": "AS-001",
          "level": "error",
          "message": {
            "text": "possible prompt injection detected in tool description: pattern matched: (?i)(ignore|disregard|bypass)\\s+(?:(?:your|all|previous|prior|any)\\s+)*(instructions?|prompts?|context|rules?|guidelines?|restrictions?|filters?)"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "run_command"
                }
              }
            }
          ]
        },
        {
          "ruleId": "AS-002",
          "level": "error",
          "message": {
            "text": "tool declares exec permission"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "run_command"
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
